/*
 * conf/modules.config
 * ------------------------------------------------------------------
 * Per-process publishDir rules. This is what makes pipeline outputs
 * actually appear under --outdir (default: results/). Without this file
 * every result stays buried in the Nextflow work/ directory.
 *
 * The publish mode is taken from params.publish_dir_mode ('copy' by default).
 * versions.yml files are never published individually - they are aggregated
 * by MultiQC into software_versions.yml.
 */

process {

    // Sensible default: publish to results/<process_name>/ and drop versions.yml.
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ---- Preprocessing & QC -------------------------------------------------
    withName: 'FASTQC' {
        publishDir = [
            path: { "${params.outdir}/fastqc" },
            mode: params.publish_dir_mode,
            pattern: "*.{html,zip}"
        ]
    }
    withName: 'FASTP' {
        publishDir = [
            path: { "${params.outdir}/fastp" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- Alignment / quantification ----------------------------------------
    withName: 'STAR_ALIGN' {
        publishDir = [
            path: { "${params.outdir}/star" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'HISAT2_ALIGN' {
        publishDir = [
            path: { "${params.outdir}/hisat2" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'SALMON_QUANT' {
        publishDir = [
            path: { "${params.outdir}/salmon" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'KALLISTO_QUANT' {
        // Kallisto produces no BAM, so RSeQC cannot auto-detect strandedness.
        // An explicit --strandedness forward/reverse is mapped to kallisto's
        // --fr-stranded / --rf-stranded; 'auto' and 'unstranded' add no flag.
        ext.args = {
            params.strandedness == 'forward' ? '--fr-stranded' :
            params.strandedness == 'reverse' ? '--rf-stranded' : ''
        }
        publishDir = [
            path: { "${params.outdir}/kallisto" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // Only publish the .bai index next to the aligner's BAM (the BAM itself is
    // already published by STAR_ALIGN / HISAT2_ALIGN).
    withName: 'SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/${params.aligner}" },
            mode: params.publish_dir_mode,
            pattern: "*.bai"
        ]
    }

    // ---- Post-alignment QC & tracks ----------------------------------------
    withName: 'RSEQC' {
        publishDir = [
            path: { "${params.outdir}/rseqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'BAM_TO_BIGWIG' {
        publishDir = [
            path: { "${params.outdir}/bam_to_bigwig" },
            mode: params.publish_dir_mode,
            pattern: "*.bw"
        ]
    }
    // GTF2BED only produces an intermediate BED12 file - not published.
    withName: 'GTF2BED' {
        publishDir = [ enabled: false ]
    }
    // GTF2GENEINFO emits an intermediate gene_id/name/biotype table that is
    // merged into the result tables - not published on its own.
    withName: 'GTF2GENEINFO' {
        publishDir = [ enabled: false ]
    }

    // ---- Quantification & differential expression --------------------------
    withName: 'FEATURECOUNTS' {
        publishDir = [
            path: { "${params.outdir}/featurecounts" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // Exon-level counts (featureCounts -f) feeding the edgeR diffSplice test.
    withName: 'FEATURECOUNTS_EXON' {
        publishDir = [
            path: { "${params.outdir}/featurecounts_exon" },
            mode: params.publish_dir_mode,
            pattern: "*.exon.featureCounts.txt"
        ]
    }
    // DESEQ2/EDGER/GSEA/GPROFILER/RMATS/ISOFORM_SWITCH/DTU/DIFFSPLICE each emit
    // a single named output directory, so they publish directly under --outdir.
    withName: 'DESEQ2|EDGER|GSEA|GPROFILER|RMATS|ISOFORM_SWITCH|DTU|DIFFSPLICE' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'STAR_FUSION' {
        publishDir = [
            path: { "${params.outdir}/star_fusion" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- Reporting ----------------------------------------------------------
    withName: 'MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'QUARTO_REPORT' {
        publishDir = [
            path: { "${params.outdir}/quarto_report" },
            mode: params.publish_dir_mode,
            pattern: "*.html"
        ]
    }

    // ---- Helper workflows: index building & reference download -------------
    withName: 'STAR_GENOME_GENERATE|HISAT2_BUILD|SALMON_INDEX|KALLISTO_INDEX' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    // DOWNLOAD_REFS: when --download_release is set, publish into a versioned
    // subfolder (e.g. <outdir>/v102) for reproducibility. saveAs also strips the
    // internal 'references/' prefix so the files sit directly in that folder.
    withName: 'DOWNLOAD_REFS' {
        publishDir = [
            path: {
                params.download_release
                    ? "${params.outdir}/v${params.download_release.toString().toLowerCase().replaceFirst('^v', '')}"
                    : "${params.outdir}"
            },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                filename.equals('versions.yml') ? null : filename.replaceFirst('^references/', '')
            }
        ]
    }
    withName: 'DOWNLOAD_GMT' {
        publishDir = [
            path: { "${params.outdir}/gmt" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
