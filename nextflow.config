/*
 * rnaseq-flow - main Nextflow configuration
 */

params {
    // Input/Output options
    input                      = null
    outdir                     = 'results'
    tracedir                   = "${params.outdir}/pipeline_info"
    publish_dir_mode           = 'copy'
    stop_at                    = null // Control pipeline stages: preQC, postQC, DE, GSEA

    // Alignment options
    aligner                    = 'star' // Options: star, hisat2, salmon, kallisto
    strandedness               = 'auto' // Options: auto (infer per-sample from RSeQC; default), unstranded, forward, reverse

    // Reference genomes (user must supply, or generate with the helper workflows)
    fasta                      = null
    gtf                        = null
    transcript_fasta           = null // Required for Salmon/Kallisto build + IsoformSwitchAnalyzeR
    gmt                        = null // Path to GMT file for GSEA
    organism                   = 'hsapiens' // Organism ID for gProfiler (e.g. hsapiens, mmusculus) and GSEA
    read_length                = 100  // Read length for rMATS
    ctat_lib                   = null // Path to CTAT Genome Library directory for STAR-Fusion
    isoform_switch             = false // Run IsoformSwitchAnalyzeR (requires aligner = salmon)
    dtu                        = false // Run DEXSeq differential transcript usage (requires aligner = salmon/kallisto)
    diffsplice                 = false // Run edgeR diffSpliceDGE (exon level: star/hisat2; transcript level: salmon/kallisto)
    design                     = null  // DESeq2/edgeR model formula override, e.g. '~ batch + condition' (default: auto from the samplesheet)

    // Download parameters
    download_refs              = false
    download_species           = 'homo_sapiens'
    download_source            = 'ensembl'
    download_release           = null  // Pin an Ensembl release for reproducibility, e.g. 102 (default: current/latest)
    download_gmt               = false // Download GMT gene sets for the organism

    // Build Indices parameters
    build_indices              = false
    genome_fasta               = null // Required for STAR/HISAT2/Salmon index build

    // Predetermined indices (optional, saves time)
    star_index                 = null
    hisat2_index               = null
    salmon_index               = null
    kallisto_index             = null

    // Resource ceilings (applied via check_max)
    max_memory                 = '128.GB'
    max_cpus                   = 16
    max_time                   = '240.h'

    // Generic
    help                       = false // Print the parameter help (from nextflow_schema.json) and exit
}

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    // Lightweight profile for syntax / channel-topology validation.
    // Combine with -stub-run, e.g.  nextflow run main.nf -profile test,docker -stub-run
    test {
        cleanup                = false
    }
}

// Wave: on-the-fly container provisioning. Processes that declare a `conda`
// directive instead of a fixed `container` (e.g. DOWNLOAD_GMT) have a minimal,
// secure image built automatically by the Wave service at run time — no need
// for a specific pre-built biocontainer to exist.
wave {
    enabled = true
}

// Base resources for every process + per-process publishDir rules.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Manifest
manifest {
    name            = 'rnaseq-flow'
    author          = 'Antigravity'
    homePage        = 'https://github.com/todo'
    description     = 'A modular bulk RNA-seq analysis pipeline (DSL2)'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '1.1.0'
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Timeline, report and trace
def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace_${trace_timestamp}.txt"
    // Emit raw numeric values (realtime in ms, memory in bytes, %cpu as a
    // number) so the run-completion summary (workflow.onComplete in main.nf)
    // can aggregate per-process resource usage reliably. The human-readable
    // resource view is the Nextflow execution report and run_summary.html.
    raw     = true
}

/*
 * check_max(): cap a per-process resource request at the params.max_* ceiling.
 * Referenced by conf/base.config.
 */
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "WARNING: Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
